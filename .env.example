# Site
NEXT_PUBLIC_SITE_URL=https://codex-blog-website.vercel.app

# Database
# Neon on Vercel should prefer the pooled connection string.
POSTGRES_URL=postgresql://USER:PASSWORD@YOUR-NEON-POOLER-HOST/neondb?sslmode=require

# Auth.js + GitHub OAuth
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_GITHUB_ID=replace-with-github-oauth-app-client-id
AUTH_GITHUB_SECRET=replace-with-github-oauth-app-client-secret
ADMIN_GITHUB_LOGINS=your-github-login

# Giscus
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=replace-with-giscus-repo-id
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=replace-with-giscus-category-id

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token

# Local MCP publishing
# Generate this in /admin/tokens, then pass it to your local MCP client.
BLOG_MCP_TOKEN=replace-with-token-generated-in-admin
